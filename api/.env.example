PORT=3000

# Nominatim (internal Postgres password for the Nominatim container)
NOMINATIM_PASSWORD=

# Nominatim geocoding URL
# Local dev: http://localhost:3002
# Inside Docker: http://nominatim:8080
NOMINATIM_URL=http://localhost:3002

# Google Sheets service account credentials
# Copy client_email and private_key from the downloaded service account JSON key file.
# Wrap GOOGLE_SA_PRIVATE_KEY in double quotes — it contains newlines.
GOOGLE_SA_EMAIL=
GOOGLE_SA_PRIVATE_KEY=""

# Target spreadsheet
# GOOGLE_SPREADSHEET_ID: found in the spreadsheet URL: /spreadsheets/d/<ID>/edit
GOOGLE_SPREADSHEET_ID=

# CORS allowed origin
CORS_ORIGIN=http://localhost:3001
